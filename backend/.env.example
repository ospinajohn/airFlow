# Base de datos PostgreSQL (Railway la provee automáticamente)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secreto para firmar tokens JWT (genera uno con: openssl rand -hex 32)
JWT_SECRET="tu-secreto-seguro-aqui"

# URL del frontend en Railway (para configurar CORS)
FRONTEND_URL="https://tu-frontend.up.railway.app"

# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=3001

NODE_ENV=production
