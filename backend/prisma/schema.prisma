// Configuración de la Base de Datos (Prisma 7)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 👤 Modelo de Usuario (Para la Etapa 3)
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  password  String
  active    Boolean   @default(true)
  projects  Project[]
  tasks     Task[]
  settings  UserSettings?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ⚙️ Configuración Personalizada por Usuario
model UserSettings {
  id                      String   @id @default(uuid())
  user                    User     @relation(fields: [userId], references: [id])
  userId                  String   @unique
  autoStartPomodoro       Boolean  @default(false)
  pomodoroWorkDuration    Int      @default(25)
  pomodoroShortBreakDuration Int   @default(5)
  pomodoroLongBreakDuration Int    @default(15)
  pomodoroCyclesUntilLongBreak Int @default(4)
  pomodoroAutoStartBreaks  Boolean  @default(true)
  showKanbanHealthCheck   Boolean  @default(true)
  weekStartsOn            Int      @default(1) // 0: Domingo, 1: Lunes
  vibrationEnabled        Boolean  @default(true)
  theme                   String   @default("dark")
  updatedAt               DateTime @updatedAt
}

// 📁 Modelo de Proyecto
model Project {
  id        String   @id @default(uuid())
  name      String
  color     String?
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ✅ Modelo de Tarea
model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("backlog") // backlog, todo, doing, done
  priority    Int       @default(1) // 1: Normal, 2: Alta, 3: Urgente
  dueDate     DateTime?
  project     Project?  @relation(fields: [projectId], references: [id])
  projectId   String?
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
}
